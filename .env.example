# ==========================================
# Bybit V5 Unified Trading Account API Keys
# ==========================================
# Generate these at: https://www.bybit.com/app/user/api-management
# Required permissions: "Contract - Orders", "Contract - Positions"
#
# Copy this file to .env and fill in your keys:
#   cp .env.example .env

BYBIT_API_KEY=your_api_key_here
BYBIT_API_SECRET=your_api_secret_here

# Set to "true" to use testnet (recommended for first-time setup)
BYBIT_TESTNET=false

# ─── Optional tuning ──────────────────────────────────────────────
# Default $ risk per trade (net loss when stopped, fees included)
# DEFAULT_RISK_USD=100.0

# Your fee tier (defaults are Bybit VIP0 linear perp). Used so risk sizing,
# breakeven, and the journal are fee-aware. Maker = limit, Taker = market.
# FEE_MAKER_RATE=0.0002
# FEE_TAKER_RATE=0.00055

# Price reference that fires the Stop Loss: MarkPrice (default, matches the
# liquidation engine so the SL always fires before liquidation) or LastPrice.
# SL_TRIGGER_BY=MarkPrice
